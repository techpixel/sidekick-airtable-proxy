# Shared secret Sidekick sends as "Authorization: Bearer <secret>"
SIDEKICK_SECRET=

# Airtable personal access token with data.records:read/write and
# data.recordComments:read/write scopes on the base below
AIRTABLE_API_KEY=

# Defaults target the YSWS - Horizons Nexus base
AIRTABLE_BASE_ID=app9SfJm8LOTJKm0A
AIRTABLE_TABLE_ID=tbllB2MlHnfep54wK
AIRTABLE_USERS_TABLE_ID=tblLsdMMbx5T5L9S2

# Optional: Hackatime STATS_API_KEY for hackatimeId lookups (omit to skip)
STATS_API_KEY=

# Optional: Slack bot token with users:read.email for author resolution fallback
SLACK_BOT_TOKEN=

PORT=3000
CACHE_TTL_MS=60000
